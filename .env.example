# Browser entry point exposed by compose.
SQBI_PORT=8080

# OpenAI-compatible model endpoint used for intent planning and summaries.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=replace-with-your-model

# Replace both values before exposing SQ-BI outside a trusted local network.
SQ_BI_TOKEN_SECRET=replace-with-a-long-random-token-secret
SQ_BI_SECRET_KEY=replace-with-a-fernet-key-or-long-random-secret

# Optional organization defaults.
SQ_BI_DEFAULT_ORG_ID=default
SQ_BI_DEFAULT_ORG_NAME=Default Organization

